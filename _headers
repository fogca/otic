# Cloudflare Pages security response headers. adapter-cloudflare requires this
# file to live in the project root (NOT static/) — it copies this file into
# the build output, then appends its own auto-generated immutable-asset
# caching rules to the same file.
/*
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: geolocation=(), microphone=(), camera=(), payment=()

